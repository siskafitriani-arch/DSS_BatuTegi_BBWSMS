import json
import streamlit as st
import matplotlib.pyplot as plt
import pandas as pd

st.subheader("📈 Riwayat Training Model")

try:
    # Load data dari file JSON
    with open('history_training.json', 'r') as f:
        data = json.load(f)
    
    train_loss = data['loss']
    val_loss = data['val_loss']
    epochs = range(1, len(train_loss) + 1)
    
    df_loss = pd.DataFrame({
        'Epoch': list(epochs),
        'Training Loss': train_loss,
        'Validation Loss': val_loss
    })
    
    fig, ax = plt.subplots()
    ax.plot(df_loss['Epoch'], df_loss['Training Loss'], 'b-o', label='Training Loss')
    ax.plot(df_loss['Epoch'], df_loss['Validation Loss'], 'r-o', label='Validation Loss')
    ax.set_title('Training vs Validation Loss')
    ax.set_xlabel('Epoch')
    ax.set_ylabel('Loss')
    ax.legend()
    ax.grid(True)
    
    st.pyplot(fig)
    
except FileNotFoundError:
    st.warning("File history_training.json tidak ditemukan. Lakukan training terlebih dahulu.")
except Exception as e:
    st.error(f"Gagal memuat data history: {e}")
