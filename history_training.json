import json

# 1. Jalankan Training
history = model.fit(
    X_train,
    y_train,
    epochs=100,
    batch_size=32,
    validation_data=(X_test, y_test),
    verbose=1
)

# 2. SIMPAN HASILNYA KE FILE (Wajib dilakukan agar bisa dibaca Streamlit)
with open('history_training.json', 'w') as f:
    json.dump(history.history, f)

print("✅ History training berhasil disimpan ke 'history_training.json'")
print(f"Total Epoch yang dijalankan: {len(history.history['loss'])}")
print(f"Loss Akhir Training: {history.history['loss'][-1]:.6f}")
print(f"Loss Akhir Validasi: {history.history['val_loss'][-1]:.6f}")
